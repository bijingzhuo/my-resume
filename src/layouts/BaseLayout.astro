---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

// 站点基本信息，后续可提取到 src/config.ts
const SITE_NAME    = '[你的名字占位]';
const SITE_TAGLINE = '[身份/职位占位]';

// 规范化 base：无论 BASE_URL 是否带末尾斜杠，统一去掉，得到 '/my-resume' 或 ''
const base = import.meta.env.BASE_URL;
const normalizedBase = base.endsWith('/') ? base.slice(0, -1) : base;

// 剥离 base 前缀后得到本地路径，始终以 / 开头
const localPath = Astro.url.pathname.slice(normalizedBase.length) || '/';
const isActive = (href: string) =>
  href === '/' ? localPath === '/' : localPath.startsWith(href);

const navLinks = [
  { href: '/',           label: '首页' },
  { href: '/projects',   label: '项目' },
  { href: '/experience', label: '经历' },
  { href: '/about',      label: '关于' },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={normalizedBase + '/favicon.svg'} />
    <link rel="icon" href={normalizedBase + '/favicon.ico'} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!--
      FOUC 预防：在任何 CSS 渲染前同步设置 data-theme。
      必须用 is:inline 保证 Astro 不 defer 这段脚本。
    -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var theme = saved
          ? saved
          : window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark'
          : 'light';
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>

  <body>
    <div class="layout">
      <!-- 侧边栏 -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <a href={normalizedBase + '/'} class="site-name">{SITE_NAME}</a>
          <p class="site-tagline">{SITE_TAGLINE}</p>
        </div>

        <nav class="sidebar-nav">
          {navLinks.map(({ href, label }) => (
            <a
              href={normalizedBase + href}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          ))}
        </nav>

        <div class="sidebar-footer">
          <button id="theme-toggle" class="theme-toggle" aria-label="切换主题">
            深色模式
          </button>
          <p class="copyright">&copy; {new Date().getFullYear()} {SITE_NAME}</p>
        </div>
      </aside>

      <!-- 主内容区 -->
      <main class="main-content">
        <div class="content-inner">
          <slot />
        </div>
      </main>
    </div>

    <!--
      主题切换逻辑：放在 body 末尾保证 DOM 已就绪。
      is:inline 使 Astro 不处理/bundle 这段脚本，保持行为可预期。
    -->
    <script is:inline>
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;

        function getTheme() {
          return document.documentElement.getAttribute('data-theme') || 'light';
        }

        function updateBtn() {
          btn.textContent = getTheme() === 'dark' ? '浅色模式' : '深色模式';
        }

        updateBtn();

        btn.addEventListener('click', function () {
          var next = getTheme() === 'dark' ? 'light' : 'dark';
          document.documentElement.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
          updateBtn();
        });
      })();
    </script>
  </body>
</html>

<style>
  /* ── 布局骨架 ── */
  .layout {
    display: flex;
    min-height: 100vh;
  }

  /* ── 侧边栏 ── */
  .sidebar {
    width: var(--sidebar-width);
    /* sticky + height:100vh 让侧边栏固定在视口，不随页面内容滚动 */
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    flex-shrink: 0;

    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-3);

    border-right: 1px solid var(--color-border);
    background-color: var(--color-bg);
    transition: border-color var(--transition), background-color var(--transition);
  }

  .sidebar-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .site-name {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-fg);
    text-decoration: none;
    transition: color var(--transition);
  }

  .site-name:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .site-tagline {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: 0;
  }

  /* ── 导航链接 ── */
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-nav a {
    display: block;
    padding: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: color var(--transition), background-color var(--transition);
  }

  .sidebar-nav a:hover {
    color: var(--color-fg);
    background-color: var(--color-bg-subtle);
    text-decoration: none;
  }

  /* aria-current="page" 标记当前页 */
  .sidebar-nav a[aria-current='page'] {
    color: var(--color-accent);
    font-weight: 600;
    background-color: var(--color-bg-subtle);
  }

  /* ── 侧边栏底部 ── */
  .sidebar-footer {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .theme-toggle {
    width: 100%;
    padding: var(--space-1);
    text-align: left;
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color var(--transition), border-color var(--transition),
      background-color var(--transition);
  }

  .theme-toggle:hover {
    color: var(--color-fg);
    border-color: var(--color-fg-muted);
    background-color: var(--color-bg-subtle);
  }

  .copyright {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: 0;
  }

  /* ── 主内容区 ── */
  .main-content {
    flex: 1;
    min-width: 0; /* 防止 flex 子元素撑破布局 */
    padding: var(--space-6) var(--space-4);
  }

  .content-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  /* ── 移动端（< 768px）：侧边栏变顶部导航 ── */
  @media (max-width: 768px) {
    .layout {
      flex-direction: column;
    }

    .sidebar {
      position: static;
      width: 100%;
      height: auto;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: var(--space-1);
      padding: var(--space-1) var(--space-2);
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }

    .sidebar-header {
      flex-direction: row;
      align-items: baseline;
      gap: var(--space-1);
    }

    .site-tagline {
      display: none; /* 小屏空间有限，隐藏副标题 */
    }

    .sidebar-nav {
      flex-direction: row;
      flex-wrap: wrap;
    }

    .sidebar-footer {
      margin-top: 0;
      margin-left: auto;
      flex-direction: row;
      align-items: center;
    }

    .copyright {
      display: none;
    }

    .main-content {
      padding: var(--space-3) var(--space-2);
    }
  }
</style>
