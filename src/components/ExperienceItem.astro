---
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'experience'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { role, company, startDate, endDate, location } = entry.data;

const formatDate = (date: Date) => date.toISOString().slice(0, 7);
---

<div class="timeline-item">
  <div class="item-role">{role}</div>
  <div class="item-company">{company}</div>
  <div class="item-sub">
    <span>{formatDate(startDate)} – {endDate ? formatDate(endDate) : 'Present'}</span>
    {location && <span class="item-location"> · {location}</span>}
  </div>
  <div class="item-content">
    <Content />
  </div>
</div>

<style>
  /*
    时间线实现：
    - border-left 是那条竖线
    - ::before 是线上的圆点
    - margin-left 为圆点留出空间，使圆点不被裁剪
  */
  .timeline-item {
    position: relative;
    margin-left: 12px;
    padding-left: var(--space-3);
    padding-bottom: var(--space-4);
    border-left: 2px solid var(--color-border);
    transition: border-color var(--transition);
  }

  /* 圆点：圆心对齐竖线，top 稍微偏下对齐文字行 */
  .timeline-item::before {
    content: '';
    position: absolute;
    left: -5px;   /* -(点宽 8px / 2) + (线宽 2px / 2) = -4 + 1 = -3，视觉补 -2px */
    top: 5px;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-accent);
    /* border 颜色跟随 bg，让圆点在不同主题下"浮"在线上 */
    border: 2px solid var(--color-bg);
    transition: background-color var(--transition), border-color var(--transition);
  }

  .item-role {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-fg);
    line-height: 1.4;
  }

  .item-company {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-top: 2px;
  }

  .item-sub {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-top: 2px;
  }

  .item-location {
    color: var(--color-fg-muted);
  }

  /* Markdown 渲染的正文，和上面的 meta 信息保持间距 */
  .item-content {
    margin-top: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-fg);
  }

  /*
    重置 global.css 里 ul/li 的 margin，
    避免 content 区域底部多余的 margin-bottom
  */
  .item-content :global(p:last-child),
  .item-content :global(ul:last-child) {
    margin-bottom: 0;
  }
</style>
