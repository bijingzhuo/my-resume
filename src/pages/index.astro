---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// 取 featured: true 的项目（最多 3 个），按 startDate 倒序
const featured = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="[你的名字占位]">
  <section class="hero">
    <h1 class="hero-name">[你的名字占位]</h1>
    <p class="hero-tagline">软件工程 · LUT University</p>
    <p class="hero-bio">
      [占位] 对分布式系统和 AI 应用感兴趣，喜欢把想法做成能跑起来的东西。
      目前在芬兰读研，偶尔写写开源项目。
    </p>
  </section>

  {featured.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>精选项目</h2>
        <a href={`${import.meta.env.BASE_URL}projects`} class="view-all">全部项目 →</a>
      </div>
      <div class="project-list">
        {featured.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <h2>联系方式</h2>
    <ul class="contact-list">
      <li>邮件：<a href="mailto:placeholder@example.com">placeholder@example.com</a></li>
      <li>GitHub：<a href="https://github.com/placeholder" target="_blank" rel="noopener noreferrer">github.com/placeholder</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  /* ── Hero 区 ── */
  .hero {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .hero-name {
    /* 覆盖 global.css h1 的 margin-bottom，hero 内间距自己管 */
    margin-bottom: var(--space-1);
  }

  .hero-tagline {
    font-size: var(--text-base);
    color: var(--color-fg-muted);
    margin-bottom: var(--space-2);
  }

  .hero-bio {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-fg-muted);
    max-width: 540px;
    margin-bottom: 0;
  }

  /* ── 各区块 ── */
  .section {
    margin-top: var(--space-6);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-3);
  }

  /* section 内的 h2 取消 global.css 里的 margin-top */
  .section h2 {
    margin-top: 0;
    margin-bottom: 0;
  }

  .view-all {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .view-all:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ── 项目列表 ── */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  /* ── 联系方式 ── */
  .contact-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-list li {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: 0;
  }
</style>
