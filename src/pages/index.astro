---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';

// 取 featured: true 的项目（最多 3 个），按 startDate 倒序
const featured = (await getCollection('projects', ({ data }) => !data.draft && data.featured))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime())
  .slice(0, 3);
---

<BaseLayout title="毕经卓">
  <section class="hero">
    <h1 class="hero-name">毕经卓</h1>
    <p class="hero-tagline">Software Engineering · LUT University</p>
    <p class="hero-bio">Curious, exploring.</p>
  </section>

  {featured.length > 0 && (
    <section class="section">
      <div class="section-header">
        <h2>Featured Projects</h2>
        <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/projects`} class="view-all">All Projects →</a>
      </div>
      <div class="project-list">
        {featured.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>
  )}

  <section class="section">
    <h2>Contact</h2>
    <ul class="contact-list">
      <li>Email: <a href="mailto:a17662522072@outlook.com">a17662522072@outlook.com</a></li>
      <li>GitHub: <a href="https://github.com/bijingzhuo" target="_blank" rel="noopener noreferrer">github.com/bijingzhuo</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  /* ── Hero 区 ── */
  .hero {
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
  }

  .hero-name {
    /* 覆盖 global.css h1 的 margin-bottom，hero 内间距自己管 */
    margin-bottom: var(--space-1);
  }

  .hero-tagline {
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-2);
  }

  .hero-bio {
    font-size: var(--text-base);
    line-height: 1.75;
    color: var(--color-fg-muted);
    max-width: 480px;
    margin-bottom: 0;
  }

  /* ── 各区块 ── */
  .section {
    margin-top: var(--space-6);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
  }

  .section h2 {
    margin-top: 0;
    margin-bottom: 0;
  }

  /* Contact section: h2 gets its own border since it has no section-header row */
  .section:not(:has(.section-header)) h2 {
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-3);
  }

  .view-all {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .view-all:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  /* ── 项目列表 ── */
  .project-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* ── 联系方式 ── */
  .contact-list {
    list-style: none;
    padding: var(--space-2) var(--space-3);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    background-color: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .contact-list li {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: 0;
  }
</style>
