---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EducationItem from '../components/EducationItem.astro';

const educations = (await getCollection('education', ({ data }) => !data.draft))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
---

<BaseLayout title="About">
  <h1>About</h1>

  <p class="intro">
    Software engineering student at LUT University. Curious, exploring.
  </p>

  <section class="section">
    <h2>Education</h2>
    <div class="timeline">
      {educations.map((entry) => (
        <EducationItem entry={entry} />
      ))}
    </div>
  </section>

  <section class="section">
    <h2>Contact</h2>
    <ul class="contact-list">
      <li>Email: <a href="mailto:a17662522072@outlook.com">a17662522072@outlook.com</a></li>
      <li>GitHub: <a href="https://github.com/bijingzhuo" target="_blank" rel="noopener noreferrer">github.com/bijingzhuo</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .intro {
    color: var(--color-fg-muted);
    line-height: 1.75;
    margin-bottom: 0;
  }

  .section {
    margin-top: var(--space-6);
  }

  /* h2 的上间距由 global.css 控制，此处只管容器 */
  .section h2 {
    margin-top: 0;
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline {
    margin-top: var(--space-2);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-list li {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: 0;
  }
</style>
