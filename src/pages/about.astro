---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EducationItem from '../components/EducationItem.astro';

const educations = (await getCollection('education', ({ data }) => !data.draft))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());
---

<BaseLayout title="关于我">
  <h1>关于我</h1>

  <p class="intro">
    [占位] 软件工程方向的研究生，目前就读于 LUT University。
    对分布式系统、AI 应用开发和开源社区感兴趣。
    喜欢把复杂的问题拆解成干净的代码。
  </p>

  <section class="section">
    <h2>教育背景</h2>
    <div class="timeline">
      {educations.map((entry) => (
        <EducationItem entry={entry} />
      ))}
    </div>
  </section>

  <section class="section">
    <h2>联系方式</h2>
    <ul class="contact-list">
      <li>邮件：<a href="mailto:placeholder@example.com">placeholder@example.com</a></li>
      <li>GitHub：<a href="https://github.com/placeholder" target="_blank" rel="noopener noreferrer">github.com/placeholder</a></li>
      <li>LinkedIn：<a href="https://linkedin.com/in/placeholder" target="_blank" rel="noopener noreferrer">linkedin.com/in/placeholder</a></li>
    </ul>
  </section>
</BaseLayout>

<style>
  .intro {
    color: var(--color-fg-muted);
    line-height: 1.75;
    margin-bottom: 0;
  }

  .section {
    margin-top: var(--space-6);
  }

  /* h2 的上间距由 global.css 控制，此处只管容器 */
  .section h2 {
    margin-top: 0;
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline {
    margin-top: var(--space-2);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .contact-list li {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin-bottom: 0;
  }
</style>
