---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const experiences = (await getCollection('experience', ({ data }) => !data.draft))
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime());

const formatDate = (date: Date) => date.toISOString().slice(0, 7);
---

<BaseLayout title="经历">
  <h1>工作经历</h1>
  <ul>
    {experiences.map((exp) => (
      <li>
        <h2>{exp.data.role}</h2>
        <p>
          {exp.data.company}
          {exp.data.location && ` · ${exp.data.location}`}
        </p>
        <p>
          {formatDate(exp.data.startDate)} – {exp.data.endDate ? formatDate(exp.data.endDate) : '至今'}
        </p>
      </li>
    ))}
  </ul>
</BaseLayout>
